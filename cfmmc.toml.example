# ====================
# 基础配置
# ====================

debug = false

[baidu_ocr]
api_key = "your_baidu_ocr_api_key"
secret_key = "your_baidu_ocr_secret_key"
url = "https://aip.baidubce.com/rest/2.0/ocr/v1/accurate_basic"

# ====================
# 账户配置
# ====================

[account]
accounts = ["account1", "account2"]
passwords = ["password1", "password2"]

# ====================
# 通知配置
# ====================

[notifier.chanify]
enabled = false
url = "https://chanify.estan.cn/v1/sender/"
token = ""

[notifier.email]
enabled = false
sender = ""
password = ""
recipient = ""

[notifier.pushgo]
enabled = false
url = "https://pushgo.estan.cn/message"
api_token = ""
channel_id = ""
password = ""
hex_key = ""
icon = ""
image = ""
